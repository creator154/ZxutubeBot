{
  "name": "Youtube Upload Bot",
  "description": "Telegram to YouTube Uploader Bot",
  "repository": "https://github.com/odysseusmax/utube",
  "logo": "https://github.com/odysseusmax/utube/raw/master/ss/logo.jpeg",
  "keywords": ["telegram", "youtube", "uploader"],
  "env": {
    "BOT_TOKEN": {
      "description": "Get from https://t.me/BotFather",
      "required": true
    },
    "SESSION_NAME": {
      "description": "Your Bot username",
      "value": "youtubeitbot",
      "required": false
    },
    "API_ID": {
      "description": "Telegram API ID",
      "required": true
    },
    "API_HASH": {
      "description": "Telegram API HASH",
      "required": true
    },
    "CLIENT_ID": {
      "description": "Google Client ID",
      "required": true
    },
    "CLIENT_SECRET": {
      "description": "Google Client Secret",
      "required": true
    },
    "BOT_OWNER": {
      "description": "Your Telegram User ID",
      "required": true
    },
    "AUTH_USERS": {
      "description": "Comma separated user IDs",
      "required": false
    },
    "VIDEO_DESCRIPTION": {
      "description": "Default video description",
      "required": false
    },
    "VIDEO_CATEGORY": {
      "description": "YouTube category id",
      "required": false
    },
    "VIDEO_TITLE_PREFIX": {
      "description": "Prefix for title",
      "required": false
    },
    "VIDEO_TITLE_SUFFIX": {
      "description": "Suffix for title",
      "required": false
    },
    "UPLOAD_MODE": {
      "description": "private/public/unlisted",
      "value": "private",
      "required": false
    },
    "DEBUG": {
      "description": "Enable debug logs",
      "required": false
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
    }
